# Django
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DB_NAME=isp_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email (optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@ispmanager.com

# Twilio (optional - for SMS notifications)
TWILIO_PHONE_NUMBER=your-phone-number
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Docker values (use these when running with docker-compose)
# DB_HOST=db
# REDIS_URL=redis://redis:6379/0

# Local values (use these when running without docker)
# DB_HOST=localhost
# REDIS_URL=redis://localhost:6379/0
